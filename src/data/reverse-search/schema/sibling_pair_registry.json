{
  "version": 1,
  "type": "sibling_pair_registry",
  "phase": "3-pre",
  "description": "Brother series pairs that must not share contentName, token, currency, or boundItemIds across chains. Used for gap audit and verified gate evaluation.",
  "policyReference": "src/data/reverse-search/schema/series_audit_policy.json",
  "pairTypes": {
    "savage_normal": {
      "labelJa": "零式 / ノーマルレイド兄弟",
      "rule": "別 chainId・別 contentName・別 token。category2 も異なること。",
      "distinguishBy": ["contentName", "token", "category2"]
    },
    "coffer_exchange": {
      "labelJa": "同一 series 内 coffer直ドロップ / 断章・トークン交換",
      "rule": "同一 chainId 内で acquisitionLink を分離。boundItemIds は非重複。",
      "distinguishBy": ["dropKind", "boundItemIds"]
    }
  },
  "validationRules": [
    {
      "id": "no_shared_contentName_across_pair",
      "severity": "blocker",
      "appliesTo": ["savage_normal"],
      "message": "兄弟 series が同一 contentName を共有している"
    },
    {
      "id": "no_shared_token_across_pair",
      "severity": "blocker",
      "appliesTo": ["savage_normal"],
      "message": "兄弟 series が同一 token/currency を共有している"
    },
    {
      "id": "no_overlapping_boundItemIds_within_pair",
      "severity": "blocker",
      "appliesTo": ["coffer_exchange"],
      "message": "coffer link と exchange link の boundItemIds が重複している"
    },
    {
      "id": "separate_chainId_for_savage_normal",
      "severity": "blocker",
      "appliesTo": ["savage_normal"],
      "message": "零式/ノーマル兄弟が同一 chainId に登録されている"
    }
  ],
